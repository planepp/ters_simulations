#!/usr/bin/env python3
import sys
import re
import subprocess
from pathlib import Path
import argparse

# --- argument parser ---
parser = argparse.ArgumentParser(
    description="Extract and visualize a vibrational mode from a multi-mode XYZ file using Jmol."
)
parser.add_argument("xyz", help="Input multi-mode XYZ file")
parser.add_argument("idx", type=float, nargs="?", help="Target mode index")
parser.add_argument("--spt", help="Optional Jmol script filename to write (default: temp_show_mode.spt)")
args = parser.parse_args()

# --- internal constants ---
rotation_angle = -45
jmol_exec = "jmol"  # edit manually if needed

xyz_file = args.xyz
target_idx = args.idx
jmol_script = args.spt if args.spt else "temp_show_mode.spt"

# --- helper to read blocks ---
def read_blocks(path):
    lines = Path(path).read_text().splitlines()
    blocks = []
    i = 0
    while i < len(lines):
        line = lines[i].strip()
        if line.isdigit():
            natoms = int(line)
            if i + 1 + natoms < len(lines):
                header = lines[i + 1]
                block = lines[i : i + 2 + natoms]
                blocks.append((header, block))
            i += 2 + natoms
        else:
            i += 1
    return blocks


# --- read and extract all modes ---
blocks = read_blocks(xyz_file)
modes = []
for header, block in blocks:
    if "frequency" in header.lower():
        floats = re.findall(r"[-+]?\d*\.\d+|\d+", header)
        if floats:
            try:
                freq = float(floats[0])
                modes.append((freq, block))
            except ValueError:
                continue

if not modes:
    print(f"No vibrational modes found in {xyz_file}.")
    sys.exit(1)

# --- always print all frequencies ---
print(f"Found {len(modes)} vibrational modes in {xyz_file}:")
for i, (freq, _) in enumerate(modes):
    print(f"  {i:3d}: {freq:.2f} cm⁻¹")

# --- if no frequency specified, exit after listing ---
if target_idx is None:
    print("\nNo index specified — exiting after listing available modes.")
    sys.exit(0)

# --- check index validity ---
if not (0 <= target_idx < len(modes)):
    print(f"Invalid mode index {target_idx}. Must be between 0 and {len(modes)-1}.")
    sys.exit(1)

freq, block = modes[int(target_idx)]
print(f"\nSelected mode {target_idx}: {freq:.3f} cm⁻¹")

# --- write temporary xyz ---
temp_xyz = "temp_mode.xyz"
Path(temp_xyz).write_text("\n".join(block) + "\n")
print(f"Wrote single-mode XYZ to {temp_xyz}")

# --- output filenames ---
xyz_name = Path(xyz_file).stem
out_png = f"{xyz_name}_{freq:.3f}.png"

if args.spt:
    jmol_script = args.spt
    print(f"Using existing Jmol script: {jmol_script}")
else:
    jmol_script = "template_jmol.spt"
    spt = f"""# autogenerated script to show mode {freq}
load {temp_xyz}
load temp_mode.xyz
rotate x -45
vibration off

# vector appearance
vector on
vector scale 5.0
vector 0.1
color vectors red

# frequency label
set echo top center
echo "{freq:.2f} cm⁻¹"
color echo white

# Save image
write image 2000 1500 "{out_png}"

"""
    Path(jmol_script).write_text(spt)
    print(f"Wrote Jmol script to {jmol_script}")

# --- run Jmol ---
cmd = [jmol_exec, "-s", jmol_script]
print("Running:", " ".join(cmd))
proc = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)

print("--- jmol stdout ---")
print(proc.stdout)
print("--- jmol stderr ---")
print(proc.stderr)
print(f"Done. Image saved to {out_png}")


#!/usr/bin/env python3

from ase.io import read, write
from ase import Atoms
import sys
import os

def convert(filename, lattice=None):
    basename, ext = os.path.splitext(filename)
    ext = ext.lower()

    if ext in [".in", ".aims"]:
        # FHI-aims → VASP
        atoms = read(filename, format='aims')

        # Optionally set lattice
        if lattice is not None:
            atoms.set_cell([lattice, lattice, lattice])
            atoms.set_pbc([True, True, True])

        output_file = f"{basename}.vasp"
        write(output_file, atoms, format='vasp')
        print(f"Converted {filename} → {output_file}")

    else:
        # VASP → FHI-aims
        atoms = read(filename, format='vasp')
        output_file = f"{basename}.in"
        write(output_file, atoms, format='aims')
        print(f"Converted {filename} → {output_file}")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: vasptoaims <input_file> [--lattice L]")
        sys.exit(1)

    filename = sys.argv[1]
    lattice = None

    if len(sys.argv) == 4 and sys.argv[2] == "--lattice":
        try:
            lattice = float(sys.argv[3])
        except ValueError:
            print("Error: lattice must be a number")
            sys.exit(1)

    convert(filename, lattice=lattice)


#!/usr/bin/env python3
import numpy as np
import re
import matplotlib.pyplot as plt
import argparse
import math

with open("aims.out", "r") as f:
    text = f.read()

### SCF
# Read density accuracy criteria
match = re.search(r"sc_accuracy_rho\s*(?:=\s*)?([-\d.Ee]+)", text)
if match:
    sc_accuracy_rho = float(match.group(1))
    print(f"SCF convergence criteria (sc_accuracy_rho) = {sc_accuracy_rho:.3e}")
else:
    raise ValueError("No sc_accuracy_rho line found in the text.")

# Read SCF table
pattern = re.compile(r"(Convergence:.*\n(?:\s*SCF\s+\d+.*\n?)+)", re.MULTILINE)
tables = pattern.findall(text)
if not tables:
    raise ValueError("No SCF convergence tables found in the file.")

last_table = tables[-1]

# Parse rows
rows = []
spin_flag = False

for line in last_table.strip().splitlines():
    match = re.match(
       r"\s*SCF\s+(\d+)\s*:\s*([-\d.E+]+)\s*\|\s*([-\d.E+\s]+)\|\s*([-\d.E+]+)\s*\|\s*([-\d.E+]+)\s*\|\s*([^\|]*)\|\s*([\d.]+)\s*s\s*\|\s*([\d.]+)\s*s",
       line
    )
    if match:
        scf = int(match.group(1))
        q_app = float(match.group(2))
        density_spin = match.group(3).split()

        if len(density_spin) == 2:
            density = float(density_spin[0])
            spin = float(density_spin[1])
            spin_flag = True
        else:
            density = float(density_spin[0])
            spin = None

        rows.append([scf, density, spin])

# Extract lists
scf_list = [r[0] for r in rows]
density_list = [r[1] for r in rows]
if spin_flag:
    spin_list = [r[2] for r in rows]

# Plot
plt.figure(figsize=(6, 6))
plt.plot(scf_list, density_list, marker="o", label="density")
#if spin_flag:
#    plt.plot(scf_list, spin_list, marker="x", label="spin")

y_line = sc_accuracy_rho
plt.axhline(y=y_line, color='k', linestyle='--', label=f"Convergence condition")

plt.xlabel("SCF iteration")
plt.yscale("log")
plt.ylabel("Density")
plt.title("SCF Convergence Evolution")
plt.grid(True)
plt.tight_layout()
plt.show()


### RELAXATION
# Extract all "Maximum force component" lines
pattern = re.compile(r"Maximum force component is\s+([-\d.E+]+)\s+eV/A", re.MULTILINE)
forces = [float(x) for x in pattern.findall(text)]

if not forces:
    raise ValueError("No 'Maximum force component' entries found in the file.")

# Read convergence criteria (threshold) from control.in
try:
    with open("control.in", "r") as f:
        control_text = f.read()
    match = re.search(r"relax_geometry\s+\S+\s+([-\d.]+)", control_text)
    if match:
        f_thresh = float(match.group(1))
    else:
        f_thresh = None
except FileNotFoundError:
    f_thresh = None

#Create step indices
steps = list(range(len(forces)))

# Plot
plt.figure(figsize=(6, 6))
plt.plot(steps, forces, marker="o", label="Max force component")
if f_thresh is not None:
    plt.axhline(y=f_thresh, color="k", linestyle="--", label=f"Threshold = {f_thresh:.3e} eV/Å")
plt.xlabel("Relaxation step")
plt.ylabel("Max force (eV/Å)")
plt.title("Geometry Relaxation Convergence Evolution")
plt.yscale("log")
plt.grid(True)
#plt.legend()
plt.tight_layout()
plt.show()


#!/usr/bin/env python
import sys, os, glob

# --- defaults ---
base_dir = "/home/planelp1/species_defaults"
default_level = "light"

# --- optional level ---
# Example args: C tight Mo really_tight
# This will assign "tight" to C and "really_tight" to Mo, everything else remains "light"
custom_level = {}
args = sys.argv[1:]
for i in range(0, len(args), 2):
    if i + 1 < len(args):
        custom_level[args[i]] = args[i + 1]

# --- start from mincontrol.in ---
with open("mincontrol.in") as f:
    control = f.read()

# --- extract atom types ---
atoms = set()
with open("geometry.in") as f:
    for line in f:
        if line.strip().startswith("atom"):
            atoms.add(line.split()[4])

print("Atom types found:", " ".join(sorted(atoms)))

# --- append species defaults ---
for atom in sorted(atoms):
    level = custom_level.get(atom, default_level)
    species_dir = os.path.join(base_dir, level)
    files = glob.glob(f"{species_dir}/*_{atom}_default")
    if files:
        print(f"Appending {files[0]} ({level})")
        with open(files[0]) as f:
            control += "\n" + f.read()
    else:
        print(f"WARNING: No default file found for {atom} ({level})")

# --- write final control.in ---
with open("control.in", "w") as f:
    f.write(control)

print("control.in updated\n")

